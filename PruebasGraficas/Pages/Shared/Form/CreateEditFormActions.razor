<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
	<MudText Class="@TitleClass">@Title</MudText>

    <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">

        @if (ShowIsActiveToggle)
        {
            <MudSwitch 	Disabled="@DisableIsActiveToggle"
						T="bool"
						Value="@IsActive"
						ValueChanged="HandleIsActiveChanged"
						Color="Color.Info"
						UncheckedColor="Color.Default" />

            <MudText Typo="Typo.subtitle1" Class="fw-bold">@_localizer["Common.Active"]</MudText>
        }

        <MudButton 	Variant="Variant.Outlined"
					Size="Size.Large"
					OnClick="OnCancel">@_localizer["Cancel"]</MudButton>

        <MudButton 	Variant="Variant.Filled"
					StartIcon="@Icons.Material.Filled.Save"
					Disabled="@Loading"
					Class="@(Loading ? "cursor-not-allowed" : "")"
					Color="Color.Info"
					Size="Size.Large"
					OnClick="OnSubmit">@_localizer["Save"]</MudButton>

    </MudStack>
</MudStack>

<br/>

@code{


	[Parameter] public bool CanChangeIsActive { get; set; } = true;
	[Parameter] public EventCallback OnCancel { get; set; }
	[Parameter] public EventCallback OnSubmit { get; set; }
	[Parameter] public bool IsActive { get; set; }
	[Parameter] public EventCallback<bool> IsActiveChanged { get; set; }
	[Parameter] public required string Title { get; set; }
	[Parameter] public string? TitleClass { get; set; } = "page-title-montserrat";
	[Parameter] public bool Loading { get; set; }

	private bool ShowIsActiveToggle => IsActiveChanged.HasDelegate;
	private bool DisableIsActiveToggle => Loading || !CanChangeIsActive;

	private async Task HandleIsActiveChanged(bool value)
	{
		if (IsActive == value)
			return;

		await IsActiveChanged.InvokeAsync(value);
	}

}
